// Patient Flow OS — Prisma schema
// Mirrors the binding schema spec. snake_case columns/tables via @map/@@map.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StaffRole {
  RECEPTIONIST
  DOCTOR
  ADMIN
}

// Which platform a stored push token came from.
//
// It matters because the token TYPE differs by platform and the FCM message
// needs a platform-specific block to carry sound/badge on iOS. NULL means
// "registered before this column existed", which can only be Android — iOS
// push did not work at all before it — so null is read as ANDROID everywhere.
enum PushPlatform {
  ANDROID
  IOS
}

// Where a booking originated. Source of truth for filtering/analytics —
// NEVER derive this from the token prefix. APP and VOICE intentionally share
// the "A" token prefix, so prefix-parsing cannot distinguish them.
enum BookingSource {
  APP
  WALK_IN
  VOICE
}

// Consultation session slot a booking belongs to (per doctor per date).
enum SessionType {
  MORNING
  EVENING
}

enum BookingStatus {
  PENDING_PAYMENT // created, awaiting payment — NO token yet
  BOOKED // payment success, token issued, waiting in queue
  ACTIVE // currently being consulted
  COMPLETED // doctor pressed DONE
  NO_SHOW // did not arrive
  CANCELLED // cancelled (may carry refund)
  EXPIRED // payment failed or never completed (webhook payment.failed / timeout sweep) — never got a token
}

enum PaymentStatus {
  CREATED
  SUCCESS
  FAILED
  REFUNDED
}

// ─── Models ───────────────────────────────────────────────

// Top-level tenant. A Hospital owns one or more Clinics and the Staff accounts
// that administer them. Tenant isolation is enforced by hospitalId: staff never
// see data outside their own hospital. Patients are intentionally cross-hospital
// (they search/book anywhere) and carry no hospitalId.
model Hospital {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  clinics Clinic[]
  staff   Staff[]

  @@map("hospitals")
}

model Patient {
  id        String   @id @default(uuid())
  name      String
  mobile    String   @unique
  age       Int?
  gender    Gender?
  // FCM registration token for push (captured at login/app-open). Single
  // device, V1. Deliberately still named fcm_token now that it is
  // platform-aware: it is an FCM token on BOTH platforms — on iOS the app
  // exchanges the APNs token for one via the Firebase SDK, so FCM stays the
  // single delivery path and the name stays accurate.
  fcmToken  String?  @map("fcm_token")
  // Platform the token above came from. Null = pre-dates this column = Android.
  pushPlatform PushPlatform? @map("push_platform")
  createdAt DateTime @default(now()) @map("created_at")

  bookings Booking[]

  @@index([mobile])
  @@map("patients")
}

model Clinic {
  id            String @id @default(uuid())
  // tenant owner — required. DB default is the migration's backfill hospital so
  // pre-tenant callers/tests never strand a row; real creates set it explicitly.
  hospitalId    String @default("00000000-0000-0000-0000-0000000000a1") @map("hospital_id")
  name          String
  address       String?
  contactNumber String? @map("contact_number")

  hospital     Hospital      @relation(fields: [hospitalId], references: [id])
  doctors      Doctor[]
  staff        Staff[]
  voiceNumbers VoiceNumber[]

  @@index([hospitalId])
  @@map("clinics")
}

// Maps an inbound telephony DID (the number a patient dialed) to the clinic that
// owns it — the voice agent passes the DID, the backend resolves the clinic (and
// thus the tenant). One clinic may own several lines; a line belongs to one clinic.
model VoiceNumber {
  id        String   @id @default(uuid())
  didNumber String   @unique @map("did_number")
  clinicId  String   @map("clinic_id")
  language  String? // default IVR language hint: en | te | hi
  createdAt DateTime @default(now()) @map("created_at")

  clinic Clinic @relation(fields: [clinicId], references: [id])

  @@index([clinicId])
  @@map("voice_numbers")
}

// Append-only record of a voice call (transcript, extracted slots, outcome). The
// agent posts this at end-of-call; idempotent by callSid. Never drives booking.
model VoiceCallLog {
  id              String   @id @default(uuid())
  callSid         String   @unique @map("call_sid")
  didNumber       String?  @map("did_number")
  callerPhone     String?  @map("caller_phone")
  clinicId        String?  @map("clinic_id")
  language        String?
  transcript      Json?
  slots           Json?
  bookingId       String?  @map("booking_id")
  outcome         String?
  durationSeconds Int?     @map("duration_seconds")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("voice_call_logs")
}

model Doctor {
  id               String @id @default(uuid())
  clinicId         String @map("clinic_id")
  name             String
  specialization   String?
  consultationFee  Int    @default(0) @map("consultation_fee")
  avgConsultMinutes Int   @default(10) @map("avg_consult_minutes")
  // Public profile photo (URL). Optional — discovery/app fall back to initials.
  photoUrl         String? @map("photo_url")

  // login (username/password) — bcrypt hash, never plaintext
  username     String? @unique
  passwordHash String? @map("password_hash")

  clinic        Clinic          @relation(fields: [clinicId], references: [id])
  bookings      Booking[]
  queueSessions QueueSession[]
  sessions      DoctorSession[]
  consultationNotes ConsultationNote[]

  @@index([clinicId])
  @@map("doctors")
}

// One consultation record per booking — the doctor's note captured at (or after)
// COMPLETE. All clinical fields except `notes` are optional so a doctor is never
// blocked from completing; `notes` defaults to "" for the same reason. Unique on
// bookingId: saving again from the doctor app upserts this row (view/edit).
//
// `bookingId` is a LOGICAL link (not a Booking FK) deliberately: the archival
// sweep DELETES settled bookings into booking_history, and a clinical note must
// outlive that move so a patient can still read it for an archived past visit.
model ConsultationNote {
  id            String    @id @default(uuid())
  bookingId     String    @unique @map("booking_id")
  doctorId      String    @map("doctor_id")
  notes         String    @default("")
  diagnosis     String?
  prescriptions String?
  followUpDate  DateTime? @map("follow_up_date") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@index([doctorId])
  @@map("consultation_notes")
}

// Recurring weekly session schedule (template) — distinct from QueueSession,
// which is a single date's live queue. Admin-managed: when a doctor consults
// (morning/evening), from what start time, how many tokens, on which weekdays.
// A doctor may not have two schedules of the SAME session type sharing a weekday
// (enforced in the admin service — overlap = same day + same session type).
model DoctorSession {
  id          String      @id @default(uuid())
  doctorId    String      @map("doctor_id")
  sessionType SessionType @map("session_type")
  startTime   String      @map("start_time") // "HH:MM" 24h local clinic time
  maxTokens   Int         @map("max_tokens")
  daysOfWeek  Int[]       @map("days_of_week") // 0=Sunday … 6=Saturday
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@map("doctor_sessions")
}

model Staff {
  id               String    @id @default(uuid())
  // tenant owner — required; DB default = backfill hospital (see Clinic.hospitalId)
  hospitalId       String    @default("00000000-0000-0000-0000-0000000000a1") @map("hospital_id")
  clinicId         String    @map("clinic_id")
  name             String
  role             StaffRole
  username         String?   @unique
  loginCredentials String    @map("login_credentials") // bcrypt password hash — never plaintext

  hospital Hospital @relation(fields: [hospitalId], references: [id])
  clinic   Clinic   @relation(fields: [clinicId], references: [id])

  @@index([hospitalId])
  @@index([clinicId])
  @@map("staff")
}

model Booking {
  id          String        @id @default(uuid())
  patientId   String        @map("patient_id")
  doctorId    String        @map("doctor_id")
  source      BookingSource @map("source") // truth for analytics/filtering — not derived from prefix
  tokenNumber String?       @map("token_number") // display only: "A001" (app/voice) / "W001" (walk-in) — null until payment success
  sessionDate DateTime      @map("session_date") @db.Date
  sessionType SessionType   @map("session_type")
  status      BookingStatus @default(PENDING_PAYMENT)
  paymentId   String?       @unique @map("payment_id")
  createdAt   DateTime      @default(now()) @map("created_at")

  // Patient-initiated cancellation.
  cancellationReason    String? @map("cancellation_reason") // optional free-text from the patient
  refundStatus          String? @map("refund_status") // razorpay refund state: pending | processed | failed

  // Consultation timestamps — captured live by the queue-advance flow.
  // (Required by spec "Consultation Timestamps"; no later point can recover them.)
  consultationStartedAt DateTime? @map("consultation_started_at") // set when promoted to ACTIVE (rank 0)
  consultationEndedAt   DateTime? @map("consultation_ended_at") // set on DONE (-> COMPLETED)

  // Physical arrival at the clinic — purely informational, SEPARATE from queue
  // position / no-show. arrived = checkedInAt != null. Never drives Redis.
  checkedInAt           DateTime? @map("checked_in_at")

  // Voice "pay-at-desk" hybrid: a phone booking issues a real token now but is
  // settled in cash/UPI at reception on arrival (no online payment on a call).
  // payAtDesk=true + an attached Payment at status CREATED = "token held, unpaid".
  // Reception's collect-payment flips the Payment to SUCCESS.
  payAtDesk             Boolean   @default(false) @map("pay_at_desk")
  // Idempotency key for voice bookings — a dropped+retried call (same callSid)
  // returns the existing booking instead of issuing a second token.
  voiceCallSid          String?   @unique @map("voice_call_sid")

  patient Patient  @relation(fields: [patientId], references: [id])
  doctor  Doctor   @relation(fields: [doctorId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  // token unique within a doctor's session (only when issued)
  @@unique([doctorId, sessionDate, sessionType, tokenNumber], name: "uq_token_per_session")
  @@index([doctorId, sessionDate, sessionType])
  @@index([patientId])
  @@map("bookings")
}

model Payment {
  id         String        @id @default(uuid())
  bookingId        String        @map("booking_id")
  amount           Int
  status           PaymentStatus @default(CREATED)
  gatewayRef       String?       @map("gateway_ref")
  razorpayOrderId  String?       @unique @map("razorpay_order_id") // set at order creation
  razorpayPaymentId String?      @unique @map("razorpay_payment_id") // set on confirm; dedup key
  razorpayRefundId String?       @map("razorpay_refund_id") // set on cancel/refund — audit trail
  createdAt        DateTime      @default(now()) @map("created_at")

  booking Booking?

  @@index([bookingId])
  @@map("payments")
}

// Live ordered queue per doctor per session.
// Ordering itself is held in Redis (sorted set) — this row is the durable
// session record + metadata. Reordering (walk-in insert, emergency priority)
// happens against the Redis structure keyed by this session.
model QueueSession {
  id              String      @id @default(uuid())
  doctorId        String      @map("doctor_id")
  sessionDate     DateTime    @map("session_date") @db.Date
  sessionType     SessionType @map("session_type")
  activeBookingId String?     @map("active_booking_id") // booking currently being consulted
  isOpen          Boolean     @default(true) @map("is_open")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@unique([doctorId, sessionDate, sessionType], name: "uq_session")
  @@index([doctorId])
  @@map("queue_sessions")
}

// Append-only mirror of completed bookings. Written ONLY by the archival job.
// No updates/deletes outside that job — permanent retention.
model BookingHistory {
  id             String        @id @default(uuid())
  bookingId      String        @unique @map("booking_id")
  patientId      String        @map("patient_id")
  doctorId       String        @map("doctor_id")
  clinicId       String        @map("clinic_id")
  source         BookingSource @map("source") // mirrored from booking — analytics truth
  tokenNumber    String?       @map("token_number")
  sessionDate    DateTime      @map("session_date") @db.Date
  sessionType    SessionType   @map("session_type")
  finalStatus    BookingStatus @map("final_status")
  paymentAmount  Int?          @map("payment_amount")
  paymentStatus  PaymentStatus? @map("payment_status")
  paymentRef     String?       @map("payment_ref")
  bookedAt              DateTime  @map("booked_at")
  consultationStartedAt DateTime? @map("consultation_started_at")
  consultationEndedAt   DateTime? @map("consultation_ended_at")
  archivedAt            DateTime  @default(now()) @map("archived_at")

  @@index([clinicId, sessionDate])
  @@index([patientId])
  @@map("booking_history")
}

// Append-only audit of staff/doctor queue-control actions (DONE / NO_SHOW /
// SKIP / PRIORITY / REINSERT). Compliance trail: WHO did WHAT to which token,
// in which session. Written after the action succeeds; never updated/deleted.
model AuditLog {
  id          String      @id @default(uuid())
  actorId     String      @map("actor_id") // JWT sub — staff or doctor id
  actorRole   String      @map("actor_role") // DOCTOR | STAFF | ADMIN
  clinicId    String?     @map("clinic_id") // JWT clinic scope (doctors may lack one)
  action      String // DONE | NO_SHOW | SKIP | PRIORITY | REINSERT
  doctorId    String      @map("doctor_id")
  sessionDate DateTime    @map("session_date") @db.Date
  sessionType SessionType @map("session_type")
  token       String? // target token, where the action targets one
  bookingId   String?     @map("booking_id") // target booking (priority/reinsert)
  metadata    Json? // extra context: afterToken, expectedToken, source, …
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([clinicId, createdAt])
  @@index([doctorId, sessionDate])
  @@map("audit_logs")
}

model AnalyticsDaily {
  id             String   @id @default(uuid())
  clinicId       String   @map("clinic_id")
  date           DateTime @db.Date
  patientsSeen   Int      @default(0) @map("patients_seen")
  avgWaitTime    Int      @default(0) @map("avg_wait_time") // minutes
  avgConsultTime Int      @default(0) @map("avg_consult_time") // minutes
  noShows        Int      @default(0) @map("no_shows")

  @@unique([clinicId, date], name: "uq_clinic_day")
  @@index([clinicId])
  @@map("analytics_daily")
}

// ══════════════════════════════════════════════════════════════════════════
//  TOKEN-BASED OPD ENGINE (ARCHITECTURE.md)
//
//  New domain, added ADDITIVELY so the legacy `Booking` god-row keeps working
//  through the migration window (ARCHITECTURE.md §Appendix A, Phase 15).
//  Aggregates link by LOGICAL id (scalar), not hard Prisma FKs — the same
//  pattern the codebase already uses for ConsultationNote/BookingHistory. This
//  keeps aggregate boundaries clean (event-sourced) and the migration purely
//  additive: NO existing model is touched.
// ══════════════════════════════════════════════════════════════════════════

// ─── OPD enums ────────────────────────────────────────────

// How an Encounter was created. ANALYTICS/AUDIT ONLY — the queue engine must
// NEVER branch on this (ARCHITECTURE.md §4, §5.1).
enum RegistrationSource {
  APP
  VOICE_AGENT
  RECEPTION
}

// Why the patient is consulting — a registration attribute, NOT a schedule slot.
enum RegistrationReason {
  NEW
  FOLLOW_UP
  REVIEW
  CORPORATE
  STAFF
  REFERRED
}

// Encounter state machine (ARCHITECTURE.md §6.1). Transitions are validated by
// the metadata-driven state machine (Phase 12), never by scattered logic.
enum EncounterStatus {
  REGISTERED // intent recorded; NO token, NOT in any queue
  ARRIVED // physically present, pre check-in
  CHECKED_IN // presence confirmed — eligible for a token
  TOKEN_ISSUED // token allocated
  WAITING // in the doctor queue
  CALLED // doctor called this token
  IN_CONSULTATION // being seen
  PAUSED // consultation paused (break / emergency interrupt)
  SKIPPED // skipped, re-queued per skip rule
  RECALLED // recalled after skip/no-show
  NO_SHOW // did not present when called
  COMPLETED // consultation done
  TRANSFERRED // moved to another doctor's queue
  CANCELLED // cancelled before consultation
}

enum CheckInMethod {
  DESK
  APP_GEOFENCE
  KIOSK
  AUTO // reception combined register+check-in
}

enum QueueEntryState {
  WAITING
  CALLED
  SKIPPED
  RECALLED
  IN_CONSULT
  REMOVED
}

enum ConsultationState {
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
  TRANSFERRED
}

enum OpSessionState {
  SCHEDULED
  OPEN
  PAUSED
  CLOSED
}

// Configurable token numbering reset (ARCHITECTURE.md §5.2). Never hardcoded.
enum TokenResetPolicy {
  PER_SESSION
  DAILY
  WEEKLY
  NEVER
}

// Serving discipline across token categories (ARCHITECTURE.md §5.3, §6).
enum QueuePolicyMode {
  SHARED_FIFO // one line, first-come
  INDEPENDENT // separate lines, caller picks category
  RATIO // interleave categories by configured weights
  MANUAL_SWITCH // doctor toggles the active category
}

// Doctor Override reason (ARCHITECTURE.md §7). First-class, audited.
enum OverrideReason {
  VIP
  MANAGEMENT
  STAFF
  RELATIVE
  KNOWN_PATIENT
  OTHER
}

// Payment mode — DECOUPLED from token issuance (ARCHITECTURE.md §3.2, §5.1).
enum OpPaymentMode {
  ONLINE
  CASH
  UPI_DESK
  CORPORATE_BILL
  WAIVED
}

// ─── OPD aggregates ───────────────────────────────────────

// The stable spine of one OPD visit intent (ARCHITECTURE.md §3). Survives token
// reissue, transfer, re-queue. serviceDate is a DAY, never a time slot.
model Encounter {
  id                 String             @id @default(uuid())
  patientId          String             @map("patient_id")
  hospitalId         String             @map("hospital_id")
  clinicId           String             @map("clinic_id")
  doctorId           String             @map("doctor_id")
  departmentId       String?            @map("department_id")
  serviceDate        DateTime           @map("service_date") @db.Date
  registrationReason RegistrationReason @default(NEW) @map("registration_reason")
  opCategoryId       String             @map("op_category_id") // -> TokenSeries
  status             EncounterStatus    @default(REGISTERED)

  // Doctor Override (ARCHITECTURE.md §7) — flagged on the encounter, never a fake token.
  override       Boolean         @default(false)
  overrideReason OverrideReason? @map("override_reason")

  // Legacy bridge: set during migration so read models can reconcile old ↔ new.
  legacyBookingId String? @unique @map("legacy_booking_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([doctorId, serviceDate])
  @@index([patientId])
  @@index([clinicId, serviceDate])
  @@index([status])
  @@map("encounters")
}

// The act of intending, per channel. source is ANALYTICS-ONLY (never read by
// the queue). channelMeta carries {callSid, deviceId, deskId, language, …}.
model Registration {
  id          String             @id @default(uuid())
  encounterId String             @map("encounter_id")
  source      RegistrationSource
  actorId     String?            @map("actor_id") // clerk/agent/self
  channelMeta Json?              @map("channel_meta")
  createdAt   DateTime           @default(now()) @map("created_at")

  @@unique([encounterId]) // one registration per encounter
  @@index([source, createdAt])
  @@map("registrations")
}

// Physical presence — the GATE to token issuance (ARCHITECTURE.md §3.1, Phase 3).
model CheckIn {
  id          String        @id @default(uuid())
  encounterId String        @unique @map("encounter_id")
  method      CheckInMethod
  checkedInBy String?       @map("checked_in_by")
  checkedInAt DateTime      @default(now()) @map("checked_in_at")

  @@map("check_ins")
}

// A waiting number in a category. Issued ONLY after check-in. displayNumber is
// rendered from the TokenSeries config — prefixes are NEVER hardcoded.
model Token {
  id            String    @id @default(uuid())
  encounterId   String    @unique @map("encounter_id")
  seriesId      String    @map("series_id") // -> TokenSeries
  sequence      Int // raw monotonic value within the series scope
  displayNumber String    @map("display_number") // e.g. "N001"
  issuedAt      DateTime  @default(now()) @map("issued_at")
  voidedAt      DateTime? @map("voided_at")

  @@unique([seriesId, sequence, issuedAt], name: "uq_token_seq")
  @@index([encounterId])
  @@map("tokens")
}

// Ordered position inside a doctor's live session queue. Volatile; the durable
// record — Redis holds the fast ordering projection (ARCHITECTURE.md §5.4).
model QueueEntry {
  id           String          @id @default(uuid())
  encounterId  String          @unique @map("encounter_id")
  opSessionId  String          @map("op_session_id")
  tokenId      String          @map("token_id")
  state        QueueEntryState @default(WAITING)
  orderKey     Float           @map("order_key") // engine-managed sort key
  enqueuedAt   DateTime        @default(now()) @map("enqueued_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  @@index([opSessionId, state])
  @@map("queue_entries")
}

// The in-room state machine (ARCHITECTURE.md §6.2). ≤1 ACTIVE per doctor.
model Consultation {
  id                          String            @id @default(uuid())
  encounterId                 String            @map("encounter_id")
  doctorId                    String            @map("doctor_id")
  roomId                      String?           @map("room_id")
  state                       ConsultationState @default(PENDING)
  startedAt                   DateTime?         @map("started_at")
  pausedAt                    DateTime?         @map("paused_at")
  resumedAt                   DateTime?         @map("resumed_at")
  endedAt                     DateTime?         @map("ended_at")
  // Emergency interruption link (ARCHITECTURE.md §8): the emergency consultation
  // that paused this one.
  interruptedByConsultationId String?           @map("interrupted_by_consultation_id")
  isEmergency                 Boolean           @default(false) @map("is_emergency")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([encounterId])
  @@index([doctorId, state])
  @@map("consultations")
}

// A doctor's live consulting window for a date (replaces legacy QueueSession).
// Decoupled from MORNING/EVENING — derives from a configurable SessionTemplate.
model OpSession {
  id                   String         @id @default(uuid())
  doctorId             String         @map("doctor_id")
  clinicId             String         @map("clinic_id")
  serviceDate          DateTime       @map("service_date") @db.Date
  sessionTemplateId    String?        @map("session_template_id")
  state                OpSessionState @default(SCHEDULED)
  activeConsultationId String?        @map("active_consultation_id")
  openedAt             DateTime?      @map("opened_at")
  closedAt             DateTime?      @map("closed_at")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  @@index([doctorId, serviceDate])
  @@map("op_sessions")
}

// Payment — DECOUPLED. May settle before, at-desk, or after; never gates a token.
model OpPayment {
  id          String        @id @default(uuid())
  encounterId String        @map("encounter_id")
  amount      Int
  mode        OpPaymentMode
  status      PaymentStatus @default(CREATED)
  gatewayRefs Json?         @map("gateway_refs")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([encounterId])
  @@map("op_payments")
}

// ─── Configuration engine (ARCHITECTURE.md §10, Phase 11) ──
// Resolved hospital → clinic → doctor (most specific wins). Zero code per hospital.

// Configurable token category + numbering (ARCHITECTURE.md §5.2).
model TokenSeries {
  id          String           @id @default(uuid())
  clinicId    String           @map("clinic_id")
  code        String // hospital key, e.g. "NORMAL_OP"
  label       String // "Normal OP"
  prefix      String           @default("") // "N" (may be empty; NEVER hardcoded)
  padWidth    Int              @default(3)
  startAt     Int              @default(1)
  resetPolicy TokenResetPolicy @default(PER_SESSION) @map("reset_policy")
  fee         Int              @default(0)
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@unique([clinicId, code], name: "uq_series_code")
  @@index([clinicId])
  @@map("token_series")
}

// Serving discipline for a live session across token categories (ARCHITECTURE.md §5.3).
model QueuePolicy {
  id          String          @id @default(uuid())
  clinicId    String          @map("clinic_id")
  doctorId    String?         @map("doctor_id") // null = clinic default
  mode        QueuePolicyMode @default(SHARED_FIFO)
  ratio       Json?           // {"SPECIAL_OP":2,"NORMAL_OP":1}
  categories  Json?           // [{seriesCode, weight}]
  skipRules   Json?           @map("skip_rules") // {maxSkips, dropAfter, reinsertPosition}
  recallRules Json?           @map("recall_rules") // {windowMinutes, afterNoShow}
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@unique([clinicId, doctorId], name: "uq_policy_scope")
  @@index([clinicId])
  @@map("queue_policies")
}

// Recurring session schedule (replaces the appointment-era MORNING/EVENING).
// expectedLoad replaces maxTokens: planning only, NEVER a queue cap.
model SessionTemplate {
  id           String   @id @default(uuid())
  doctorId     String   @map("doctor_id")
  clinicId     String   @map("clinic_id")
  label        String   @default("") // free-form, e.g. "Morning", "Evening OP"
  dayOfWeek    Int      @map("day_of_week") // 0=Sun … 6=Sat
  startTime    String   @map("start_time") // "HH:MM" local
  endTime      String?  @map("end_time")
  expectedLoad Int      @default(0) @map("expected_load")
  roomId       String?  @map("room_id")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([doctorId, dayOfWeek])
  @@map("session_templates")
}

// ─── Event store (ARCHITECTURE.md §12.1, Phase 13) ─────────
// Append-only source of truth. State is a fold over these events; read models
// (CQRS, Phase 14) are projections; the audit trail is inherent (§12.5).
model DomainEvent {
  id            String   @id @default(uuid())
  streamType    String   @map("stream_type") // "Encounter" | "Consultation" | "OpSession" | "Config"
  streamId      String   @map("stream_id") // aggregate id
  version       Int // per-stream monotonic version (optimistic concurrency)
  type          String // "TokenIssued", "PatientCalled", …
  payload       Json
  metadata      Json?    // {actorId, actorRole, clinicId, source, correlationId}
  occurredAt    DateTime @default(now()) @map("occurred_at")
  globalSeq     BigInt   @default(autoincrement()) @map("global_seq") // total order for replay

  @@unique([streamType, streamId, version], name: "uq_stream_version")
  @@index([streamType, streamId])
  @@index([type, occurredAt])
  @@index([globalSeq])
  @@map("domain_events")
}

// ─── CQRS read side (ARCHITECTURE.md §12.2, Phase 14) ──────
// Denormalized projection of one encounter's live queue state, maintained by the
// projector folding the event stream. Optimized for the read models: live queue,
// doctor dashboard, reception roster, display board, patient tracking. Fully
// rebuildable from domain_events (drop + replay).
model QueueReadModel {
  encounterId String          @id @map("encounter_id")
  clinicId    String          @map("clinic_id")
  doctorId    String          @map("doctor_id")
  opSessionId String?         @map("op_session_id")
  patientName String          @map("patient_name")
  tokenNumber String?         @map("token_number")
  category    String? // TokenSeries.code
  status      EncounterStatus
  orderKey    Float?          @map("order_key")
  isOverride  Boolean         @default(false) @map("is_override")
  isEmergency Boolean         @default(false) @map("is_emergency")
  // Registration source — carried for ANALYTICS read models ONLY, never ordering.
  source      String?
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at")

  @@index([opSessionId, status])
  @@index([doctorId, status])
  @@index([clinicId])
  @@map("queue_read_model")
}

// Per-projector replay cursor (last globalSeq consumed). Lets a projector resume
// deterministically and lets a rebuild start from 0 (Phase 13/14: event replay).
model ProjectionCursor {
  name      String   @id
  globalSeq BigInt   @default(0) @map("global_seq")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("projection_cursors")
}

// ─── Configuration engine — generic scoped config (Phase 11) ──
// Any hospital-specific behaviour NOT already modelled by a dedicated table
// (TokenSeries/QueuePolicy/SessionTemplate) lives here as scoped key/value.
// Resolution: DOCTOR → CLINIC → HOSPITAL → code default (most specific wins), so
// onboarding a hospital is pure configuration — zero hospital-specific code.
model HospitalConfig {
  id        String   @id @default(uuid())
  scopeType String   @map("scope_type") // HOSPITAL | CLINIC | DOCTOR
  scopeId   String   @map("scope_id")
  key       String
  value     Json
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([scopeType, scopeId, key], name: "uq_config")
  @@index([key])
  @@map("hospital_config")
}
