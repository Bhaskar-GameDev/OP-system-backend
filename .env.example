# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Comma-separated allowed CORS origins (web preview, Tauri, RN dev server).
# Defaults to local dev origins when unset. Set real origins in production.
CORS_ORIGINS=http://localhost:1420,http://tauri.localhost,https://tauri.localhost

# ─── Postgres (matches docker-compose.yml) ─────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://pfos:pfos_local_pw@localhost:5432/patient_flow_os?schema=public

# ─── Redis (queue engine — required, not optional) ─────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Auth ──────────────────────────────────────────────
JWT_SECRET=replace_me_with_long_random_string
OTP_EXPIRY_SECONDS=300

# ─── MSG91 (patient/staff OTP via SMS) ─────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_OTP_TEMPLATE_ID=

# ─── Razorpay (payments — sandbox first) ───────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Firebase Cloud Messaging (push) ───────────────────
# Path to service-account json, OR inline the JSON via FCM_SERVICE_ACCOUNT_JSON
FCM_SERVICE_ACCOUNT_PATH=./secrets/fcm-service-account.json
FCM_SERVICE_ACCOUNT_JSON=

# ─── Voice agent (internal API consumed by hospital-voice-agent) ───────────
# Shared secret the voice agent sends in the x-voice-secret header. If unset,
# the /voice API is hard-disabled (deny all). Must match the agent's value.
VOICE_INTERNAL_SECRET=long_random_string_that_matches_backend_env
# Clinic used when a call's DID doesn't map to any Clinic.voiceDid (single-tenant/dev).
VOICE_DEFAULT_CLINIC_ID=00000000-0000-0000-0000-000000000100